<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Online Offline PWA</title>

    <link rel="manifest" href="manifest.json">
    <meta name="theme-color" content="#2196F3">

    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f2f6ff;
            text-align: center;
            padding: 20px;
        }

        h1 {
            color: #2196F3;
        }

        .container {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 20px;
            margin-top: 30px;
        }

        .card {
            background-color: white;
            width: 180px;
            padding: 15px;
            border-radius: 10px;
            box-shadow: 0px 0px 8px gray;
        }

        img {
            width: 120px;
            height: 120px;
        }
    </style>
</head>

<body>

    <h1>Online and Offline Web Page using PWA</h1>
    <p>This page works online and offline using Service Worker caching.</p>

    <div class="container">
        <div class="card">
            <img src="img/bathroomprod.jpg" alt="Bathroom Product">
            <p>Bathroom Product</p>
        </div>

        <div class="card">
            <img src="img/camera.jpg" alt="Camera">
            <p>Camera</p>
        </div>

        <div class="card">
            <img src="img/headphone.jpeg" alt="Headphone">
            <p>Headphone</p>
        </div>

        <div class="card">
            <img src="img/cosmetics.jpg" alt="Cosmetics">
            <p>Cosmetics</p>
        </div>
    </div>

    <script src="js/start.js"></script>

</body>
</html>
