import 'package:flutter/material.dart';

void main() {
  runApp(const MessageToggleApp());
}

// Program 8: Message Toggle App
class MessageToggleApp extends StatelessWidget {
  const MessageToggleApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: "Message Toggle App",
      debugShowCheckedModeBanner: false,
      home: const MessageToggleHome(),
    );
  }
}

class MessageToggleHome extends StatefulWidget {
  const MessageToggleHome({super.key});

  @override
  State<MessageToggleHome> createState() => _MessageToggleHomeState();
}

class _MessageToggleHomeState extends State<MessageToggleHome> {
  bool _showCollegeMessage = true;
  int toggleCount = 0;

  void _toggleMessage() {
    setState(() {
      _showCollegeMessage = !_showCollegeMessage;
      toggleCount++;
    });

    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text("Message changed successfully! Toggle count: $toggleCount"),
        duration: const Duration(seconds: 1),
        backgroundColor: Colors.blue,
      ),
    );
  }

  void _resetMessage() {
    setState(() {
      _showCollegeMessage = true;
      toggleCount = 0;
    });

    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(
        content: Text("Message reset successfully!"),
        duration: Duration(seconds: 1),
        backgroundColor: Colors.red,
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    String message = _showCollegeMessage
        ? "RV College of Engineering!"
        : "Go Change the World!";

    IconData messageIcon = _showCollegeMessage
        ? Icons.school
        : Icons.public;

    Color cardColor = _showCollegeMessage
        ? Colors.blue.shade50
        : Colors.green.shade50;

    Color iconColor = _showCollegeMessage
        ? Colors.blue
        : Colors.green;

    return Scaffold(
      appBar: AppBar(
        title: const Text(
          "Message Toggle App",
          style: TextStyle(
            color: Colors.white,
            fontWeight: FontWeight.bold,
          ),
        ),
        backgroundColor: Colors.deepPurple,
        centerTitle: true,
      ),

      body: Container(
        width: double.infinity,
        decoration: BoxDecoration(
          gradient: LinearGradient(
            colors: [
              Colors.deepPurple.shade50,
              Colors.blue.shade50,
            ],
            begin: Alignment.topCenter,
            end: Alignment.bottomCenter,
          ),
        ),

        child: SingleChildScrollView(
          child: Padding(
            padding: const EdgeInsets.all(20.0),

            child: Column(
              children: [
                const SizedBox(height: 30),

                const Text(
                  "Program 8",
                  style: TextStyle(
                    fontSize: 28,
                    fontWeight: FontWeight.bold,
                    color: Colors.deepPurple,
                  ),
                ),

                const SizedBox(height: 8),

                const Text(
                  "Toggle between two messages using StatefulWidget",
                  textAlign: TextAlign.center,
                  style: TextStyle(
                    fontSize: 16,
                    color: Colors.black54,
                  ),
                ),

                const SizedBox(height: 30),

                Card(
                  elevation: 8,
                  color: cardColor,
                  shape: RoundedRectangleBorder(
                    borderRadius: BorderRadius.circular(20),
                  ),

                  child: Padding(
                    padding: const EdgeInsets.all(25.0),

                    child: Column(
                      children: [
                        Icon(
                          messageIcon,
                          size: 90,
                          color: iconColor,
                        ),

                        const SizedBox(height: 20),

                        AnimatedSwitcher(
                          duration: const Duration(milliseconds: 500),
                          transitionBuilder: (child, animation) {
                            return ScaleTransition(
                              scale: animation,
                              child: child,
                            );
                          },
                          child: Text(
                            message,
                            key: ValueKey<String>(message),
                            textAlign: TextAlign.center,
                            style: const TextStyle(
                              fontSize: 30,
                              fontWeight: FontWeight.bold,
                              color: Colors.black87,
                            ),
                          ),
                        ),

                        const SizedBox(height: 20),

                        Container(
                          padding: const EdgeInsets.symmetric(
                            horizontal: 18,
                            vertical: 10,
                          ),
                          decoration: BoxDecoration(
                            color: Colors.white,
                            borderRadius: BorderRadius.circular(30),
                            border: Border.all(
                              color: Colors.deepPurple,
                              width: 1.5,
                            ),
                          ),
                          child: Text(
                            "Toggle Count: $toggleCount",
                            style: const TextStyle(
                              fontSize: 18,
                              fontWeight: FontWeight.w600,
                              color: Colors.deepPurple,
                            ),
                          ),
                        ),
                      ],
                    ),
                  ),
                ),

                const SizedBox(height: 30),

                Row(
                  mainAxisAlignment: MainAxisAlignment.center,
                  children: [
                    ElevatedButton.icon(
                      onPressed: _toggleMessage,
                      icon: const Icon(Icons.swap_horiz),
                      label: const Text("Toggle Message"),
                      style: ElevatedButton.styleFrom(
                        backgroundColor: Colors.deepPurple,
                        foregroundColor: Colors.white,
                        padding: const EdgeInsets.symmetric(
                          horizontal: 18,
                          vertical: 14,
                        ),
                      ),
                    ),

                    const SizedBox(width: 15),

                    ElevatedButton.icon(
                      onPressed: _resetMessage,
                      icon: const Icon(Icons.refresh),
                      label: const Text("Reset"),
                      style: ElevatedButton.styleFrom(
                        backgroundColor: Colors.red,
                        foregroundColor: Colors.white,
                        padding: const EdgeInsets.symmetric(
                          horizontal: 18,
                          vertical: 14,
                        ),
                      ),
                    ),
                  ],
                ),

                const SizedBox(height: 30),

                const Divider(
                  thickness: 2,
                  color: Colors.deepPurple,
                ),

                const SizedBox(height: 15),

                Card(
                  elevation: 4,
                  shape: RoundedRectangleBorder(
                    borderRadius: BorderRadius.circular(15),
                  ),
                  child: const Padding(
                    padding: EdgeInsets.all(16.0),
                    child: Column(
                      children: [
                        Text(
                          "Widgets Used",
                          style: TextStyle(
                            fontSize: 22,
                            fontWeight: FontWeight.bold,
                            color: Colors.deepPurple,
                          ),
                        ),

                        SizedBox(height: 10),

                        Text(
                          "MaterialApp, Scaffold, AppBar, Container, Column, Card, "
                          "Text, Icon, ElevatedButton, Row, AnimatedSwitcher, "
                          "SnackBar, Divider and StatefulWidget.",
                          textAlign: TextAlign.center,
                          style: TextStyle(
                            fontSize: 16,
                            color: Colors.black87,
                          ),
                        ),
                      ],
                    ),
                  ),
                ),
              ],
            ),
          ),
        ),
      ),

      floatingActionButton: FloatingActionButton(
        onPressed: _toggleMessage,
        backgroundColor: Colors.deepPurple,
        child: const Icon(Icons.swap_horiz, color: Colors.white),
      ),
    );
  }
}
